# Database - PostgreSQL for Docker
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/insighflow

# Security
SECRET_KEY=insightflow-super-secret-key-change-in-production-2026
REFRESH_SECRET_KEY=insightflow-refresh-secret-key-change-in-production-2026

# Environment
ENVIRONMENT=development
DEBUG=true
AUTO_CREATE_DB=true

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:8003","http://127.0.0.1:8003","http://localhost:5173","http://127.0.0.1:5173"]
